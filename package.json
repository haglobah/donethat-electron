{
  "name": "donethat",
  "version": "0.1.5",
  "description": "Remembering your work for you",
  "main": "main.js",
  "scripts": {
    "build:css": "postcss styles.css -o ./build/output.css --verbose",
    "build:webpack": "webpack --config webpack.config.js",
    "build:prepare": "npm run build:css && npm run build:webpack",
    "start": "npm run build:prepare && electron .",
    "build": "npm run build:prepare && electron-builder",
    "build:linux": "npm run build:prepare && electron-builder --linux",
    "build:win": "npm run build:prepare && electron-builder --win",
    "build:all:arm64": "npm run build:prepare && electron-builder -mwl",
    "build:all:x64": "npm run build:prepare && electron-builder -mwl --x64",
    "build:all": "npm run build:all:arm64 && npm run build:all:x64",
    "release:arm64": "dotenv -- npm run build:prepare && dotenv -- electron-builder -mwl --publish always",
    "release:x64": "dotenv -- npm run build:prepare && dotenv -- electron-builder -mwl --x64 --publish always",
    "release": "npm run release:arm64 && npm run release:x64"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donethatai/donethat-releases.git"
  },
  "author": {
    "name": "Christoph Hartmann",
    "email": "christoph@donethat.ai"
  },
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/donethatai/donethat-releases/issues"
  },
  "homepage": "https://donethat.ai",
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "babel-loader": "^10.0.0",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-notarize": "^1.2.2",
    "postcss-cli": "^11.0.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.6",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.9",
    "firebase": "^11.3.1",
    "node-fetch": "^3.3.2",
    "tailwindcss": "^4.0.6"
  },
  "build": {
    "appId": "com.donethat.app",
    "productName": "Done That",
    "afterSign": "scripts/notarize.js",
    "icon": "resources/icon_inverse.png",
    "artifactName": "${productName} ${arch}.${ext}",
    "files": [
      "main.js",
      "firebase-config.js",
      "src/**/*",
      "build/**/*",
      "resources/**/*",
      "src-main/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "donethatai",
        "repo": "donethat-releases",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSUIElement": 1
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.png",
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        {
          "from": "resources/app.manifest",
          "to": "app.manifest"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "desktop": {
        "StartupWMClass": "done-that",
        "NoDisplay": true,
        "Type": "Application"
      }
    },
    "compression": "maximum"
  }
}
