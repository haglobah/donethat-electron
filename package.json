{
  "name": "donethat",
  "version": "1.4.5",
  "description": "DoneThat",
  "main": "main.js",
  "scripts": {
    "predev": "node scripts/postinstall-macos-micstatus.js",
    "build:css": "postcss styles.css -o ./build/output.css --verbose",
    "build:webpack": "webpack --config webpack.config.js",
    "prebuild:prepare": "node scripts/postinstall-macos-micstatus.js",
    "build:prepare": "npm run build:css && npm run build:webpack",
    "postinstall": "node scripts/postinstall-macos-micstatus.js || electron-builder install-app-deps",
    "dev": "npm run build:prepare && electron .",
    "dev:linux": "npm run build:prepare && electron . --no-sandbox",
    "build": "npm run build:prepare && electron-builder",
    "build:mac:x64": "npm run build:prepare && electron-builder --mac --x64",
    "build:mac:arm64": "npm run build:prepare && electron-builder --mac --arm64",
    "build:win:x64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --x64",
    "build:win:arm64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --arm64",
    "build:linux:x64": "npm run build:prepare && electron-builder --linux --x64",
    "build:linux:arm64": "npm run build:prepare && electron-builder --linux --arm64",
    "upload:mac:x64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --mac --x64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=x64",
    "upload:mac:arm64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --mac --arm64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=arm64",
    "upload:win:x64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --x64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=x64",
    "upload:win:arm64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --arm64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=arm64",
    "upload:linux:x64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --linux --x64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=x64",
    "upload:linux:arm64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --linux --arm64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=arm64",
    "release": "echo 'Build strategy: Run the upload:PLATFORM:ARCH command matching your current system architecture'",
    "update:check": "npx npm-check-updates",
    "update:interactive": "npx npm-check-updates -i",
    "update:deps": "npx npm-check-updates -u && npm install",
    "update:prod": "npx npm-check-updates -u --dep prod && npm install",
    "update:dev": "npx npm-check-updates -u --dep dev && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donethatai/donethat-releases.git"
  },
  "author": {
    "name": "Christoph Hartmann",
    "email": "christoph@donethat.ai"
  },
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/donethatai/donethat-releases/issues"
  },
  "homepage": "https://donethat.ai",
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@tailwindcss/postcss": "^4.1.15",
    "babel-loader": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^10.0.0",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "electron-notarize": "^1.2.2",
    "npm-check-updates": "^19.1.1",
    "postcss-cli": "^11.0.1",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@firebase/analytics": "^0.10.19",
    "@firebase/app": "^0.14.4",
    "@firebase/auth": "^1.11.0",
    "@firebase/firestore": "^4.9.2",
    "@firebase/functions": "^0.13.1",
    "@langchain/core": "^1.0.1",
    "@langchain/google-genai": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "firebase": "^12.4.0",
    "get-windows": "^9.2.3",
    "node-fetch": "^3.3.2",
    "node-global-key-listener": "^0.3.0",
    "sharp": "^0.34.4",
    "tailwindcss": "^4.1.15"
  },
  "build": {
    "appId": "com.donethat.app",
    "productName": "DoneThat",
    "afterSign": "scripts/notarize.js",
    "icon": "resources/icon_inverse.png",
    "artifactName": "${productName}-${arch}.${ext}",
    "generateUpdatesFilesForAllChannels": true,
    "protocols": [
      {
        "name": "DoneThat Protocol",
        "schemes": [
          "donethat"
        ]
      }
    ],
    "files": [
      "main.js",
      "firebase-config.js",
      "src/**/*",
      "bin/**/*",
      "build/**/*",
      "resources/**/*",
      "src-main/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "donethatai",
        "repo": "donethat-releases",
        "releaseType": "draft"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSUIElement": 1,
        "NSCameraUseContinuityCameraDeviceType": true,
        "NSMicrophoneUsageDescription": "DoneThat needs microphone access to record audio for transcription and analysis."
      },
      "artifactName": "${productName}-${arch}.${ext}",
      "notarize": false
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png",
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        {
          "from": "resources/app.manifest",
          "to": "app.manifest"
        }
      ],
      "artifactName": "${productName}-${arch}.${ext}",
      "signtoolOptions": {
        "sign": "./scripts/digicert-sign-windows.js"
      },
      "files": [
        "!**/node_modules/node-global-key-listener/bin/MacKeyServer",
        "!**/node_modules/node-global-key-listener/bin/LinuxKeyServer"
      ]
    },
    "nsis": {
      "runAfterFinish": true,
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "multiLanguageInstaller": true
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "desktop": {
        "entry": {
          "StartupWMClass": "donethat",
          "NoDisplay": true,
          "Type": "Application"
        }
      },
      "artifactName": "${productName}-${arch}.${ext}"
    },
    "compression": "maximum"
  }
}
