{
  "name": "donethat",
  "version": "0.1.3",
  "description": "Remembering your work for you",
  "main": "main.js",
  "scripts": {
    "build:css": "postcss styles.css -o ./build/output.css --verbose",
    "build:webpack": "webpack --config webpack.config.js",
    "start": "npm run build:css && npm run build:webpack && electron .",
    "build": "npm run build:css && npm run build:webpack && electron-builder",
    "build:all": "npm run build:css && npm run build:webpack && electron-builder -mwl",
    "release": "dotenv -- npm run build:all && dotenv -- electron-builder -mwl --publish always"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donethatai/donethat-electron.git"
  },
  "author": "Christoph Hartmann",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/donethatai/donethat-releases/issues"
  },
  "homepage": "https://donethat.ai",
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "babel-loader": "^10.0.0",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-notarize": "^1.2.2",
    "postcss-cli": "^11.0.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.6",
    "canvas": "^3.1.0",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.9",
    "firebase": "^11.3.1",
    "node-fetch": "^3.3.2",
    "tailwindcss": "^4.0.6"
  },
  "type": "module",
  "build": {
    "appId": "com.donethat.app",
    "productName": "donethat",
    "afterSign": "scripts/notarize.js",
    "files": [
      "main.js",
      "firebase-config.js",
      "src/**/*",
      "build/**/*",
      "resources/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "donethatai",
        "repo": "donethat-releases"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "asarUnpack": [
        "node_modules/canvas"
      ],
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        {
          "from": "resources/app.manifest",
          "to": "app.manifest"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
