{
  "name": "donethat",
  "version": "2.0.0",
  "description": "DoneThat",
  "main": "main.js",
  "scripts": {
    "predev": "node scripts/build-os-helpers.js",
    "generate:icons": "node scripts/generate-icons.js",
    "build:css": "postcss styles.css -o ./build/output.css --verbose",
    "build:webpack": "webpack --config webpack.config.js",
    "prebuild:prepare": "node scripts/build-os-helpers.js",
    "build:prepare": "npm run build:css && npm run build:webpack",
    "release:prepare": "node scripts/ensure-release-tag.js",
    "postinstall": "node scripts/build-os-helpers.js || electron-builder install-app-deps",
    "dev": "npm test && npm run build:prepare && electron .",
    "dev:linux": "npm test && npm run build:prepare && electron . --no-sandbox",
    "build": "npm run build:prepare && electron-builder",
    "build:mac:x64": "npm run build:prepare && electron-builder --mac --x64",
    "build:mac:arm64": "npm run build:prepare && electron-builder --mac --arm64",
    "build:win:x64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --x64",
    "build:win:arm64": "dotenv -- npm run build:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --arm64",
    "build:linux:x64": "npm run build:prepare && electron-builder --linux --x64 --config.asar=false",
    "build:linux:arm64": "npm run build:prepare && electron-builder --linux --arm64 --config.asar=false",
    "upload:mac:x64": "dotenv -- npm run build:prepare && npm run release:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --mac --x64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=x64",
    "upload:mac:arm64": "dotenv -- npm run build:prepare && npm run release:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --mac --arm64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=arm64",
    "upload:win:x64": "dotenv -- npm run build:prepare && npm run release:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --x64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=x64",
    "upload:win:arm64": "dotenv -- npm run build:prepare && npm run release:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --win --arm64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=arm64",
    "upload:linux:x64": "dotenv -- npm run build:prepare && npm run release:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --linux --x64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=x64 --config.asar=false",
    "upload:linux:arm64": "dotenv -- npm run build:prepare && npm run release:prepare && dotenv -- cross-env ELECTRON_BUILDER_SIGN=true electron-builder --linux --arm64 --publish always --config.extraMetadata.main=main.js --config.publish.channel=arm64 --config.asar=false",
    "release": "echo 'Build strategy: Run the upload:PLATFORM:ARCH command matching your current system architecture'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "update:check": "npx npm-check-updates",
    "update:interactive": "npx npm-check-updates -i",
    "update:deps": "npx npm-check-updates -u && npm install",
    "update:prod": "npx npm-check-updates -u --dep prod && npm install",
    "update:dev": "npx npm-check-updates -u --dep dev && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donethatai/donethat-electron.git"
  },
  "author": {
    "name": "DoneThat",
    "email": "support@donethat.ai"
  },
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/donethatai/donethat-electron/issues"
  },
  "homepage": "https://github.com/donethatai/donethat-electron",
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4.2.2",
    "babel-loader": "^10.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-notarize": "^1.2.2",
    "jest": "^30.3.0",
    "npm-check-updates": "^19.6.6",
    "postcss-cli": "^11.0.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@firebase/analytics": "^0.10.21",
    "@firebase/app": "^0.14.10",
    "@firebase/auth": "^1.12.2",
    "@firebase/firestore": "^4.13.0",
    "@firebase/functions": "^0.13.3",
    "@langchain/core": "^1.1.38",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.4.1",
    "@rive-app/canvas-single": "^2.36.0",
    "audiobuffer-to-wav": "^1.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "firebase": "^12.11.0",
    "get-windows": "^9.3.0",
    "jimp": "^1.6.0",
    "looks-same": "^10.0.1",
    "mediabunny": "^1.40.1",
    "node-addon-api": "^8.7.0",
    "node-fetch": "^3.3.2",
    "tailwindcss": "^4.2.2"
  },
  "optionalDependencies": {
    "electron-liquid-glass": "^1.1.1"
  },
  "overrides": {
    "tar": "7.5.8"
  },
  "build": {
    "appId": "com.donethat.app",
    "productName": "DoneThat",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "bin/**/*"
    ],
    "afterSign": "scripts/notarize.js",
    "icon": "resources/icon-launcher.png",
    "artifactName": "${productName}-${arch}.${ext}",
    "generateUpdatesFilesForAllChannels": true,
    "protocols": [
      {
        "name": "DoneThat Protocol",
        "schemes": [
          "donethat"
        ]
      }
    ],
    "files": [
      "main.js",
      "firebase-config.js",
      "src/**/*",
      "bin/**/*",
      "build/**/*",
      "resources/**/*",
      "src-main/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "donethatai",
        "repo": "donethat-releases",
        "releaseType": "draft"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icon",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "binaries": [
        "bin/mic-monitor"
      ],
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSCameraUseContinuityCameraDeviceType": true,
        "NSMicrophoneUsageDescription": "DoneThat needs microphone access to record audio for transcription and analysis.",
        "NSAudioCaptureUsageDescription": "DoneThat needs system audio access to capture playback audio."
      },
      "artifactName": "${productName}-${arch}.${ext}",
      "notarize": false
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon-launcher.ico",
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        {
          "from": "resources/app.manifest",
          "to": "app.manifest"
        }
      ],
      "artifactName": "${productName}-${arch}.${ext}",
      "signtoolOptions": {
        "sign": "./scripts/digicert-sign-windows.js"
      }
    },
    "nsis": {
      "runAfterFinish": true,
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "multiLanguageInstaller": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon-launcher.png",
      "category": "Utility",
      "desktop": {
        "entry": {
          "StartupWMClass": "donethat",
          "Type": "Application"
        }
      },
      "artifactName": "${productName}-${arch}.${ext}"
    },
    "compression": "maximum"
  }
}
