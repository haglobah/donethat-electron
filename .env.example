# GitHub release publishing
GH_TOKEN=YOUR_GITHUB_TOKEN

# macOS notarization via App Store Connect API key
APP_STORE_CONNECT_KEY_ID=YOUR_APP_STORE_CONNECT_KEY_ID
APP_STORE_CONNECT_ISSUER_ID=YOUR_APP_STORE_CONNECT_ISSUER_ID
APP_STORE_CONNECT_PRIVATE_KEY_PATH=./AuthKey_YOUR_KEY_ID.p8
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID

# Legacy macOS notarization fallback
APPLE_ID=YOUR_APPLE_ID_EMAIL
APPLE_ID_PASSWORD=YOUR_APP_SPECIFIC_PASSWORD

# Windows Azure Trusted Signing
SIGN_WINDOWS=false
SKIP_WINDOWS_SIGNING=false
AZURE_SIGN_DLIB=PATH_TO_AZURE_TRUSTED_SIGNING_DLIB
AZURE_SIGN_METADATA=PATH_TO_AZURE_TRUSTED_SIGNING_METADATA_JSON

# Optional release/build behavior
ENFORCE_NOTARIZATION=false
